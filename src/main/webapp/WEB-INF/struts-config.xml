<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts-config PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN" "http://struts.apache.org/dtds/struts-config_1_3.dtd">
<struts-config>

    <form-beans>
        <form-bean name="contractForm" type="sample.ContractForm" />
    </form-beans>

    <action-mappings>
        <action path="/contract" type="sample.ContractAction" name="contractForm" scope="request">
            <forward name="success" path="/result.jsp" />
            <forward name="error" path="/input.jsp" />
        </action>
        <action path="/checkName" type="sample.ContractCheckAction" />
    </action-mappings>
    
    <message-resources parameter="sample.ApplicationResources" />
</struts-config>